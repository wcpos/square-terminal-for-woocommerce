{
  "name": "wcpos/square-terminal-for-woocommerce",
  "description": "Square Terminal payments for WooCommerce.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1",
    "square/square": "^45.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.10"
  },
  "autoload-dev": {
    "psr-4": {
      "WCPOS\\WooCommercePOS\\SquareTerminal\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml.dist",
    "lint": "phpcs --standard=./.phpcs.xml.dist",
    "build:scoped-vendor": [
      "test -f tools/php-scoper.phar || (mkdir -p tools && curl -L https://github.com/humbug/php-scoper/releases/latest/download/php-scoper.phar -o tools/php-scoper.phar)",
      "rm -rf build/scoped vendor_scoped",
      "php tools/php-scoper.phar add-prefix --config=scoper.inc.php --output-dir=build/scoped --force",
      "mkdir -p vendor_scoped",
      "cp -R build/scoped/* vendor_scoped/",
      "php tools/fix-scoped-autoload.php"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "platform": {
      "php": "8.1.0"
    }
  }
}
